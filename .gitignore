# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Data & artifacts (demo artifacts under data/demo ARE committed; jobs are not)
data/jobs/
data/raw/
data/downloads/
*.pt
*.pth
*.onnx
# exclude weight CONTENTS (not the dir itself — a negation cannot re-include
# from inside an excluded directory), then re-include the one shippable model:
# the style encoder is trained on our own simulations (licence-clean, ~350 KB)
# and is required by the deployed demo
weights/*
!weights/style_encoder.pt

# NDA-RESTRICTED DATA — SoccerNet content must NEVER be committed or
# redistributed in any form (videos, annotations, JSONs, crops, file lists).
data/soccernet/
**/soccernet_data/
*.SoccerNet*

# Secrets — never commit keys
.env
.env.*
!.env.example
*.key
secrets/

# Large media not part of the bundled demo
*.mkv
*.avi

# Demo media policy: data/demo parquet/json + preview.mp4 ARE committed so the
# app is instantly explorable; the full-res source & annotated renders are
# regenerated by `python scripts/build_demo.py`
data/demo/**/input.mp4
data/demo/**/media/annotated.mp4

# Experiment tracking
wandb/
runs/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Env
.env
