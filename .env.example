# Copy to .env and fill in. NEVER commit .env — it is gitignored.
# LLM report/Q&A (primary provider; template fallback used if absent)
GEMINI_API_KEY=
# Optional alternative LLM provider
ANTHROPIC_API_KEY=
# Roboflow Universe (detector fine-tune dataset download)
ROBOFLOW_API_KEY=
# SoccerNet NDA password (data is NDA-restricted: local use only, never commit,
# never upload to third-party services — see docs/data_sources.md)
SOCCERNET_PASSWORD=
